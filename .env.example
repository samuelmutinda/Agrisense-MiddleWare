# =============================================================================
# AgriSense Middleware Configuration
# Copy this file to .env and fill in your values
# Note: docker compose variable interpolation reads .env by default, or use
# `docker compose --env-file .env.docker up -d` for the Docker-specific values.
# =============================================================================

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://agrisense:yourpassword@localhost:5432/agrisense

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-here

# ChirpStack LoRaWAN Integration
CHIRPSTACK_BASE_URL=http://localhost:8080
CHIRPSTACK_API_TOKEN=your-chirpstack-api-token
CHIRPSTACK_WEBHOOK_TOKEN=your-webhook-secret-token

# =============================================================================
# OPTIONAL SETTINGS (with defaults)
# =============================================================================

# Application Settings
APP_NAME=AgriSense Middleware
DEBUG=false

# InfluxDB Time-Series Database (optional - for telemetry persistence)
# INFLUXDB_URL=https://us-east-1-1.aws.cloud2.influxdata.com
# INFLUXDB_TOKEN=your-influxdb-token
# INFLUXDB_ORG=your-org
# INFLUXDB_BUCKET_RAW=telemetry-raw
# INFLUXDB_BUCKET_DOWNSAMPLED=telemetry-downsampled-1h
# INFLUXDB_BUCKET_KPI=kpi-metrics
# INFLUXDB_BUCKET_DIGITAL_TWIN=digital_twin
# INFLUXDB_ENABLED=true

# ── Local InfluxDB + Grafana (docker-compose) ─────────────────────────
# When running docker compose up, the following are used to auto-provision
# the InfluxDB instance and Grafana dashboards.
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_TOKEN=my-super-secret-auth-token
# INFLUXDB_ORG=agrisense
# INFLUXDB_ENABLED=true

# Grafana admin credentials (docker-compose only)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=agrisense
# GRAFANA_PORT=3000

# Path to the digital twin CSV for the ingest script
# CSV_PATH=digital_twin_balanced_20000_seed42.csv

# SendGrid Email (optional)
# SENDGRID_API_KEY=SG.your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=notifications@yourdomain.com
# SENDGRID_FROM_NAME=AgriSense Notifications

# Twilio SMS/Voice (optional)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# Africa's Talking SMS (optional - for African markets)
# AT_USERNAME=your-africastalking-username
# AT_API_KEY=your-africastalking-api-key

# Firebase Cloud Messaging (optional - for push notifications)
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Google Maps API (optional - for route optimization)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Sysadmin Bootstrap (optional - creates initial admin user)
# SYSADMIN_EMAIL=admin@yourdomain.com
# SYSADMIN_PASSWORD=secure-admin-password
